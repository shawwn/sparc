{
  "name": "sparclisp",
  "version": "0.0.5",
  "description": "Arc Lisp for Racket",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shawwn/sparc.git"
  },
  "bin": {
    "arc": "bin/arc.js",
    "sparc": "bin/sparc.js"
  },
  "main": "news.arc",
  "author": "Shawn Presser <shawnpresser@gmail.com>",
  "license": "MIT",
  "private": false,
  "dependencies": {},
  "scripts": {
    "postinstall": "node bin/postinstall.js",
    "racket": "./bin/racket/bin/racket",
    "raco": "./bin/racket/bin/raco",
    "pkg": "./bin/racket/bin/raco pkg",
    "dev": "DEV=1 bin/sparc",
    "start": "PULL=10 FLUSH=nil bin/sparc"
  }
}
